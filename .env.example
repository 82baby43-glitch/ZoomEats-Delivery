NEXT_PUBLIC_SUPABASE_URL=https://njrrhckegbfqhwkqkzvw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard

# Server-only (Vercel + Supabase secrets — never commit real values):
# STRIPE_API_KEY=sk_test_...              # or STRIPE_SECRET_KEY (same value)
# STRIPE_WEBHOOK_SECRET=whsec_...         # Stripe Dashboard → Webhooks signing secret
#   Local dev: run `npm run stripe:listen` and paste the whsec_... from CLI output here
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...   # optional; server redirect checkout does not require it
# STRIPE_MCP_KEY=ek_test_...              # Cursor MCP only — NOT used by ZoomEats app
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Webhook URL: {SUPABASE_URL}/functions/v1/stripe-webhook (deploy with --no-verify-jwt)
# RECONCILE_CRON_SECRET=random-secret    # For /api/admin/reconcile cron

# Required to apply migrations / configure auth (use ONE for migrate, all three for Google setup):
# SUPABASE_ACCESS_TOKEN=sbp_xxx   # https://supabase.com/dashboard/account/tokens
# DATABASE_URL=postgresql://postgres.njrrhckegbfqhwkqkzvw:PASSWORD@aws-0-us-west-2.pooler.supabase.com:6543/postgres
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# Optional: comma-separated admin emails auto-promoted on login
NEXT_PUBLIC_ADMIN_EMAILS=
